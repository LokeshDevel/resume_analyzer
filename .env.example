# ============================================
# Resume Analyzer — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env
# ============================================

# --- LLM + Analysis ---
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# --- OCR (Scanned PDF / Image fallback) ---
# Get free key: https://ocr.space/ocrapi (25,000 requests/month free)
OCR_SPACE_API_KEY=your_ocr_space_key_here

# --- Database ---
# MongoDB Atlas free tier: https://www.mongodb.com/cloud/atlas
# Local: mongodb://localhost:27017/
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=resume_analyzer
MONGODB_COLLECTION=analyses

# --- Server ---
FLASK_PORT=5000
FLASK_DEBUG=true
